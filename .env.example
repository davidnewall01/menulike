# Copy to .env for local dev (.env is gitignored). Railway sets these per-environment.

# Postgres. A plain postgresql:// URL is rewritten to postgresql+asyncpg:// for the
# app engine, and to a sync driver for Alembic migrations.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menulike

# Subdomain base for {slug}.<domain> tenant hosting.
PLATFORM_BASE_DOMAIN=menulike.app

# Auth signing secret. MUST be overridden in production (the dev sentinel below
# trips a fail-closed guard when ENVIRONMENT=production).
JWT_SECRET_KEY=dev-insecure-change-me

# S3 (used from a later phase).
S3_BUCKET=
S3_REGION=ap-southeast-2

# SQLAlchemy engine echo for debugging SQL.
DB_ECHO=false

# development | production. Only "production" arms the JWT fail-closed guard.
ENVIRONMENT=development
